// smdl format on

@(noinline)
export marmit_result marmit(
  color reflectance = color(0.3),  ///< The dry reflectance of the underlying material.
  float water_thickness = 0.01,    ///< The equivalent water-film thickness in centimeters.
  float wet_fraction = 1.0,        ///< The fraction of the surface covered by water, in [0, 1].
  float suspension_ior = 1.53,     ///< Real refractive index n_i of particles suspended in the film.
  float suspension_k = 0.0,        ///< Imaginary refractive index k_i of the suspended particles.
  float suspension_fraction = 0.0, ///< Volume fraction d_i of suspension in the film; 0 = pure water.
) {
  // Optical constants of water at each wavelength: its own n_w and alpha_w. In the
  // common pure-water case these are the effective medium directly; a suspension,
  // if any, mixes them into an effective (n, alpha) further below.
  //
  // The absorption spans ~6 decades with sharp vibrational bands, so it stays a
  // table lookup. The refractive index, in contrast, is smooth and low-curvature,
  // so we skip the table and evaluate it as a polynomial below. `s` is the
  // wavelength remapped to [-1, 1]; we collect it (and the absorption) per lane in
  // one contiguous pass, then evaluate n(s) on the whole color at once.
  color absorption(0);  // alpha_w, absorption coefficient of water in cm^-1
  color s(0);           // wavelength mapped to [-1, 1] for the index polynomial
  for (int i = 0; i < $WAVELENGTH_BASE_MAX; i++) {
    const float frac = saturate(($state.wavelength_base[i] - MARMIT_MIN_WAVELENGTH) / (MARMIT_MAX_WAVELENGTH - MARMIT_MIN_WAVELENGTH));
    float w = (MARMIT_TABLE_SIZE - 1) * frac;
    const int w0 = #min(int(#floor(w)), MARMIT_TABLE_SIZE - 2);
    w -= w0;
    absorption[i] = lerp(MARMIT_TABLE_ABSORPTIONS[w0], MARMIT_TABLE_ABSORPTIONS[w0 + 1], w);
    s[i] = 2.0 * frac - 1.0;
  }
  // Real refractive index of water (Segelstein), degree-6 polynomial fit in the
  // remapped wavelength s = 2*(lambda - 400)/2100 - 1. Max abs error 1.2e-3 over
  // 400..2500 nm -- below the r12 fit's own error, so effectively exact here. This
  // is pure vectorized Horner (7 FMAs, no gather): the generated code drops the
  // per-lane table gathers and the 8 KB index table entirely.
  const auto ior = return_from {
    auto n = -0.0000601351 * s - 0.0248482921;
    n = n * s - 0.0005980717;
    n = n * s + 0.0015633866;
    n = n * s - 0.0109188837;
    n = n * s - 0.0244547175;
    n = n * s + 1.3129684894;
    return n;
  };
  // Effective medium the light travels through. With no suspended particles this is
  // just water. When a suspension is present (volume fraction d_i > 0), form the
  // complex permittivities e = (n + i k)^2 of water and of the particles, volume-mix
  // them (e = d_i e_i + (1 - d_i) e_w, MARMIT-2), and take the principal square root
  // back to an effective complex index; alpha = 4 pi k / lambda. The particle side
  // (n_i, k_i) is a pair of scalar constants, so only the water/mix side is per-lane.
  // With d_i = 0 this reduces exactly to water, so the branch is a skippable add-on.
  color n = ior;             // effective refractive index
  color alpha = absorption;  // effective absorption coefficient in cm^-1
  if (suspension_fraction > 0.0) {
    const auto d = suspension_fraction;
    // wavelength in cm, recovered from the normalized s used by the index polynomial
    const auto lambda = (MARMIT_MIN_WAVELENGTH + 0.5 * (s + 1.0) * (MARMIT_MAX_WAVELENGTH - MARMIT_MIN_WAVELENGTH)) * 1.0e-7;
    // imaginary index of water from its absorption coefficient: k_w = alpha_w lambda / (4 pi)
    const auto k_w = absorption * lambda * 0.07957747154594767;
    const auto ew_re = ior * ior - k_w * k_w;
    const auto ew_im = 2.0 * ior * k_w;
    const float ei_re = suspension_ior * suspension_ior - suspension_k * suspension_k;
    const float ei_im = 2.0 * suspension_ior * suspension_k;
    const auto e_re = d * ei_re + (1.0 - d) * ew_re;
    const auto e_im = d * ei_im + (1.0 - d) * ew_im;
    const auto mag = #sqrt(e_re * e_re + e_im * e_im);
    n = #sqrt(0.5 * (mag + e_re));
    // k = Im(sqrt(e)). Since (n + i k)^2 = e gives 2 n k = e_im, take k = e_im/(2n)
    // rather than sqrt((mag - e_re)/2): the latter cancels catastrophically in
    // float32 when absorption is weak (e_im small, so mag ~ e_re). Here n ~ 1.3-1.5
    // and e_im >= 0, so this is stable and positive.
    const auto k = e_im / (2.0 * n);
    alpha = 12.566370614359172 * k / lambda;  // 4 pi k / lambda
  }
  // Diffuse (hemispherically integrated) Fresnel reflectance of the air->water
  // interface, r12. The exact expression is a long rational-plus-logarithm form;
  // this is our cheap fit r12 = v * P(v) / Q(v) with v = (n - 1) / (n + 1), exact
  // at n = 1 and monotone for all n >= 1. Max abs error ~1.7e-4 (RMSE ~1.1e-4)
  // over the water index range, using two divides and no log/pow. (1 - r12 equals
  // PROSPECT's average transmittance tav(90 deg, n).)
  const auto r12 = return_from {
    const auto v = (n - 1.0) / (n + 1.0);
    const auto num = (((-6.087330777978 * v + 5.072538780150) * v - 2.292800947895) * v + 5.106344072818) * v + 0.666666666667;
    const auto den = (-14.079305083126 * v + 15.544722876889) * v + 1.0;
    return saturate(v * num / den);
  };
  const auto t12 = 1 - r12;
  // Downward water->air diffuse transmittance and reflectance, via the standard
  // n^2 relation t21 = (1 - r12) / n^2.
  const auto t21 = t12 / (n * n);
  const auto r21 = 1 - t21;
  // One-way transmittance of the water layer of optical depth x = alpha * L.
  // tau(x) = (1 - x) exp(-x) + x^2 E1(x); this is our cheap fit tau = exp(-x) P/Q
  // that reproduces tau(0) = 1 and the exact 2 exp(-x)/x tail with one exp and one
  // divide (no exponential integral, no pow). Max abs error ~3.9e-4 for all x >= 0.
  const auto tau = return_from {
    const auto x = #min(alpha * water_thickness, 50.0);
    const auto num = (1.236150246012 * x + 3.672877420834) * x + 1.0;
    const auto den = ((0.618075123006 * x + 3.664716300259) * x + 4.621903634050) * x + 1.0;
    return saturate(#exp(-x) * num / den);
  };
  const auto tau2_reflectance = tau * tau * reflectance;
  // Reflectance of the fully wetted surface: the dry reflectance seen through the
  // water film with the interface reflections and the geometric series of internal
  // bounces summed in closed form.
  const auto wet = saturate(t12 * t21 * tau2_reflectance / (1 - r21 * tau2_reflectance));
  // Blend the wetted and dry reflectances over the surface as a generalized power
  // mean (MARMIT-2's areal mixing). wet_fraction = 1 recovers `wet`, 0 recovers the
  // dry reflectance.
  const auto e = 1.0 / MARMIT_MIXING_EXPONENT;
  const auto mixed = #pow(wet_fraction * #pow(wet, e) + (1.0 - wet_fraction) * #pow(reflectance, e), MARMIT_MIXING_EXPONENT);
  return marmit_result(reflectance: saturate(mixed), reflectance_wet: wet);
}

// ---------------------------------------------------------------------------
// Empirical soil albedo
//
// A standalone parametric soil reflectance model over 400..2298 nm, unrelated to
// the wetting model above and sharing this module only for packaging. It maps
// four normalized [0, 1] pedogenic parameters -- humus (darkens), iron (pigment
// load), aridity (hot/dry hematite vs cool/moist goethite), and moisture -- to a
// dry-state albedo spectrum. The 6 logit-space component curves are stored at 261
// uniformly-spaced knots and linearly interpolated onto '$state.wavelength_base';
// the conversion to the underlying lightness/chroma/redness color parameters
// happens internally, and the logistic link keeps every output strictly in
// (0, 1). Max reflectance error vs. the full-resolution model is ~5e-3.
// ---------------------------------------------------------------------------

export const float SOIL_MIN_WAVELENGTH = 400.0;
export const float SOIL_MAX_WAVELENGTH = 2298.0;
export const int SOIL_TABLE_SIZE = 261;

// The 6 spectral component curves in logit space at each of the 261 knots:
// constant, lightness, chroma, yellow-red, water, and water-squared terms.
// smdl format off
export static const auto SOIL_CURVES = auto[261](
