// NOTE: This module is non-standard!
#smdl

// MARMIT -- a physically based way to layer a film of water over an arbitrary
// diffuse reflectance spectrum, darkening and spectrally reshaping it the way a
// wet surface differs from a dry one. It is the reflective, water-on-top analog
// of the leaf model in `prospect.smdl`, and is built the same way: interpolate
// tabulated optical constants of water per wavelength, then evaluate a small
// closed-form radiative-transfer expression using cheap analytic fits in place
// of the special functions the reference model calls.
//
// Unlike the original soil-oriented papers, this module carries NO soil (or any
// other material) data: the material being wetted is whatever `reflectance` the
// caller passes in. Only the optical constants of pure water are baked in.
//
// References:
//   Bablet et al. (2018)   -- MARMIT
//   Dupiau et al. (2022)   -- MARMIT-2
//   Segelstein (1981)      -- real refractive index of water
//   Buiteveld/Kou/Wieliczka -- absorption coefficient of water (cm^-1)

using ::math import *;

export struct marmit_result {
  // Reflectance after wetting: the `wet_fraction`-weighted mix of the wetted
  // and dry reflectances (this is the model's primary output).
  color reflectance = color(0);

  // Reflectance of the fully wetted surface (i.e. `wet_fraction` = 1), exposed
  // as a convenience since it is computed along the way.
  color reflectance_wet = color(0);
};

// The absorption table spans 400..2500 nm on a uniform ~8 nm grid (264 entries,
// endpoints included), linearly resampled from the previously shipped 4 nm table
// (itself decimated from the 1 nm MARMIT reference parameter file) on exactly the
// endpoint-inclusive grid this module looks up. alpha_w spans ~6 decades with
// sharp vibrational bands, but the model
// only ever uses it through the layer transmittance tau = exp(-alpha_w * L) * P/Q
// below, which saturates to 0 wherever absorption is strong -- so the ~8%
// relative error this grid leaves in the strong bands is swallowed there (tau is
// 0 either way). End to end, the wet reflectance stays within one 8-bit quantum
// of a far finer table for typical substrates (it scales with the dry
// reflectance, so very bright surfaces see a bit more). See
// misc/plot_marmit_downsample.py for the analysis. The refractive index is fit
// analytically instead (see below), so it needs no table.
export const float MARMIT_MIN_WAVELENGTH = 400.0;
export const float MARMIT_MAX_WAVELENGTH = 2500.0;
export const int MARMIT_TABLE_SIZE = 264;
// Empirical exponent for the wet/dry areal mixing (generalized power mean),
// carried over from MARMIT-2.
export const float MARMIT_MIXING_EXPONENT = 2.27;

