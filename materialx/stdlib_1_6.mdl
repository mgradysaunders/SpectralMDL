// Nodedef: ND_triplanarprojection_vector3 is represented by a nodegraph: NG_triplanarprojection_vector3
// Nodedef: ND_triplanarprojection_vector4 is represented by a nodegraph: NG_triplanarprojection_vector4

export @(pure macro) auto mx_constant_float(const float mxp_value = 0.0) = mxp_value;
export @(pure macro) auto mx_constant_color3(const color mxp_value = color(0.0)) = mxp_value;
export @(pure macro) auto mx_constant_color4(const core::color4 mxp_value = core::mk_color4(0.0)) = mxp_value;
export @(pure macro) auto mx_constant_vector2(const float2 mxp_value = float2(0.0)) = mxp_value;
export @(pure macro) auto mx_constant_vector3(const float3 mxp_value = float3(0.0)) = mxp_value;
export @(pure macro) auto mx_constant_vector4(const float4 mxp_value = float4(0.0)) = mxp_value;
export @(pure macro) auto mx_constant_boolean(const bool mxp_value = false) = mxp_value;
export @(pure macro) auto mx_constant_integer(const int mxp_value = 0) = mxp_value;
export @(pure macro) auto mx_constant_matrix33(const float3x3 mxp_value = float3x3(1.0)) = mxp_value;
export @(pure macro) auto mx_constant_matrix44(const float4x4 mxp_value = float4x4(1.0)) = mxp_value;
export @(pure macro) auto mx_constant_string(const string mxp_value = "") = mxp_value;
export @(pure macro) auto mx_constant_filename(const string mxp_value = "") = mxp_value;

export @(macro) float mx_ramplr_float(
  const float mxp_valuel = 0.0, 
  const float mxp_valuer = 0.0, 
  const float2 mxp_texcoord = state::texture_coordinate(0).xy) = math::lerp(mxp_valuel, mxp_valuer, math::clamp(mxp_texcoord.x, 0.0, 1.0));

export @(macro) color mx_ramplr_color3(
  const color mxp_valuel = color(0.0),
  const color mxp_valuer = color(0.0),
  const float2 mxp_texcoord = state::texture_coordinate(0).xy) = math::lerp(mxp_valuel, mxp_valuer, math::clamp(mxp_texcoord.x, 0.0, 1.0));

export @(macro) core::color4 mx_ramplr_color4(
  const core::color4 mxp_valuel = core::mk_color4(0.0),
  const core::color4 mxp_valuer = core::mk_color4(0.0),
  const float2 mxp_texcoord = state::texture_coordinate(0).xy) = core::color4(
      math::lerp(mxp_valuel.rgb, mxp_valuer.rgb, math::clamp(mxp_texcoord.x, 0.0, 1.0)), 
      math::lerp(mxp_valuel.a,   mxp_valuer.a,   math::clamp(mxp_texcoord.x, 0.0, 1.0)));

export @(macro) float2 mx_ramplr_vector2(
  const float2 mxp_valuel = float2(0.0),
  const float2 mxp_valuer = float2(0.0),
  const float2 mxp_texcoord = state::texture_coordinate(0).xy) = math::lerp(mxp_valuel, mxp_valuer, math::clamp(mxp_texcoord.x, 0.0, 1.0));

export @(macro) float3 mx_ramplr_vector3(
  const float3 mxp_valuel = float3(0.0),
  const float3 mxp_valuer = float3(0.0),
  const float2 mxp_texcoord = state::texture_coordinate(0).xy) = math::lerp(mxp_valuel, mxp_valuer, math::clamp(mxp_texcoord.x, 0.0, 1.0));

export @(macro) float4 mx_ramplr_vector4(
  const float4 mxp_valuel = float4(0.0),
  const float4 mxp_valuer = float4(0.0),
  const float2 mxp_texcoord = state::texture_coordinate(0).xy) = math::lerp(mxp_valuel, mxp_valuer, math::clamp(mxp_texcoord.x, 0.0, 1.0));

