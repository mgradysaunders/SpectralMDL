export float mx_blur_float(float mxp_in = 0.0, float mxp_size = 0.0, core::mx_filter_type mxp_filtertype = core::mx_filter_type(core::mx_filter_type_box)) {
  // Not implemented: mx_blur_float
  return mxp_in;
}

