  const float mxp_valuet = 0.0,
  const float mxp_valueb = 0.0,
  const float2 mxp_texcoord = state::texture_coordinate(0).xy) = math::lerp(mxp_valuet, mxp_valueb, math::clamp(mxp_texcoord.y, 0.0, 1.0));

