export float3x3 mx_creatematrix_vector3_matrix33(
  float3 mxp_in1 = float3(1.0, 0.0, 0.0),
  float3 mxp_in2 = float3(0.0, 1.0, 0.0),
  float3 mxp_in3 = float3(0.0, 0.0, 1.0)) {
  return float3x3(
    mxp_in1[0], mxp_in1[1], mxp_in1[2],
    mxp_in2[0], mxp_in2[1], mxp_in2[2],
    mxp_in3[0], mxp_in3[1], mxp_in3[2]);
}


export float4x4 mx_creatematrix_vector3_matrix44(
  float3 mxp_in1 = float3(1.0, 0.0, 0.0),
  float3 mxp_in2 = float3(0.0, 1.0, 0.0),
  float3 mxp_in3 = float3(0.0, 0.0, 1.0),
  float3 mxp_in4 = float3(0.0)) {
  return float4x4(
    mxp_in1[0], mxp_in1[1], mxp_in1[2], 0.0,
    mxp_in2[0], mxp_in2[1], mxp_in2[2], 0.0,
    mxp_in3[0], mxp_in3[1], mxp_in3[2], 0.0,
    mxp_in4[0], mxp_in4[1], mxp_in4[2], 1.0);
}


export float4x4 mx_creatematrix_vector4_matrix44(
  float4 mxp_in1 = float4(1.0, 0.0, 0.0, 0.0),
  float4 mxp_in2 = float4(0.0, 1.0, 0.0, 0.0),
  float4 mxp_in3 = float4(0.0, 0.0, 1.0, 0.0),
  float4 mxp_in4 = float4(0.0, 0.0, 0.0, 1.0)) {
  return float4x4(
    mxp_in1[0], mxp_in1[1], mxp_in1[2], mxp_in1[3],
    mxp_in2[0], mxp_in2[1], mxp_in2[2], mxp_in2[3],
    mxp_in3[0], mxp_in3[1], mxp_in3[2], mxp_in3[3],
    mxp_in4[0], mxp_in4[1], mxp_in4[2], mxp_in4[3]);
}

export float mx_extract_color3(color mxp_in = color(0.0), int mxp_index = 0) {
  float3 rgb(mxp_in);
  switch (mxp_index) {
    case 0: return rgb.x;
    case 1: return rgb.y;
    default: return rgb.z;
  }
}

export float mx_extract_color4(core::color4 mxp_in = core::mk_color4(0.0), int mxp_index = 0)
{
  switch (mxp_index)
  {
    case 0: return float3(mxp_in.rgb).x;
    case 1: return float3(mxp_in.rgb).y;
    case 2: return float3(mxp_in.rgb).z;
    default: return mxp_in.a;
  }
}

export float mx_extract_vector2(float2 mxp_in = float2(0.0), int mxp_index = 0) {
  switch (mxp_index) {
    case 0: return mxp_in.x;
    default: return mxp_in.y;
  }
}

export float mx_extract_vector3(float3 mxp_in = float3(0.0), int mxp_index = 0) {
  switch (mxp_index) {
    case 0: return mxp_in.x;
    case 1: return mxp_in.y;
    default: return mxp_in.z;
  }
}

export float mx_extract_vector4(float4 mxp_in = float4(0.0), int mxp_index = 0) {
  switch (mxp_index) {
    case 0: return mxp_in.x;
    case 1: return mxp_in.y;
    case 2: return mxp_in.z;
    default: return mxp_in.w;
  }
}

