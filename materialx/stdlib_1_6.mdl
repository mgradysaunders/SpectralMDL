export float mx_noise2d_float(float mxp_amplitude = 1.0, float mxp_pivot = 0.0, float2 mxp_texcoord = state::texture_coordinate(0).xy) {
  return noise::mx_perlin_noise_float(mxp_texcoord) * mxp_amplitude + mxp_pivot;
}

export float2 mx_noise2d_float2(float2 mxp_amplitude = float2(1.0), float mxp_pivot = 0.0, float2 mxp_texcoord = state::texture_coordinate(0).xy) {
  return noise::mx_perlin_noise_float3(mxp_texcoord).xy * mxp_amplitude + mxp_pivot;
}

export float3 mx_noise2d_float3(float3 mxp_amplitude = float3(1.0), float mxp_pivot = 0.0, float2 mxp_texcoord = state::texture_coordinate(0).xy) {
  return noise::mx_perlin_noise_float3(mxp_texcoord) * mxp_amplitude + mxp_pivot;
}

export float4 mx_noise2d_float4(float4 mxp_amplitude = float4(1.0), float mxp_pivot = 0.0, float2 mxp_texcoord = state::texture_coordinate(0).xy) {
  return float4(noise::mx_perlin_noise_float3(mxp_texcoord), noise::mx_perlin_noise_float(mxp_texcoord + float2(19, 73))) * mxp_amplitude + mxp_pivot;
}

export @(macro) float mx_noise3d_float(
  float mxp_amplitude = 1.0,
  float mxp_pivot = 0.0, 
  float3 mxp_position = state::transform_point(state::coordinate_internal, state::coordinate_object, state::position())) {
  return noise::mx_perlin_noise_float(mxp_position) * mxp_amplitude + mxp_pivot;
}

export @(macro) float2 mx_noise3d_float2(
  float2 mxp_amplitude = float2(1.0),
  float  mxp_pivot = 0.0,
  float3 mxp_position = state::transform_point(state::coordinate_internal, state::coordinate_object, state::position())) {
  float3 value = noise::mx_perlin_noise_float3(mxp_position);
  return core::mx_swizzle_xy(value) * mxp_amplitude + mxp_pivot;
}

export @(macro) float3 mx_noise3d_float3(
  float3 mxp_amplitude = float3(1.0),
  float  mxp_pivot = 0.0,
  float3 mxp_position = state::transform_point(state::coordinate_internal, state::coordinate_object, state::position())) {
  return noise::mx_perlin_noise_float3(mxp_position) * mxp_amplitude + mxp_pivot;
}

export @(macro) float4 mx_noise3d_float4(
  float4 mxp_amplitude = float4(1.0),
  float  mxp_pivot = 0.0,
  float3 mxp_position = state::transform_point(state::coordinate_internal, state::coordinate_object, state::position())) {
  return float4(noise::mx_perlin_noise_float3(mxp_position), noise::mx_perlin_noise_float(mxp_position + float3(19, 73, 29))) * mxp_amplitude + mxp_pivot;
}

